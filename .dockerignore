# Build from an explicit allowlist. Local state and secrets must never enter the context.
**

!requirements.txt
!run.py
!gunicorn.conf.py
!alembic.ini
!entrypoint.sh
!app/
!app/**
!migrations/
!migrations/**
!templates/
!templates/**
!static/
!static/**

# Defence in depth for common local secret, browser, and cache paths.
.env
.env.*
.runtime/
browser/
browser_data/
user_data/
user_data_*/
**/__pycache__/
**/*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.cache/
.git/
.agents/
.codex/
