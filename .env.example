# Copy only as a reference. install.sh generates real URL-safe secrets automatically.
# Bind to the VM's static private LAN or VPN IPv4 address, never a public address.
BIND_ADDRESS=192.168.1.50
PORT=5000

# Generate with: openssl rand -hex 48
SECRET_KEY=replace-with-a-long-random-value
# Required only to claim the first operator account; keep it secret afterward.
BOOTSTRAP_TOKEN=replace-with-a-long-random-value

POSTGRES_USER=twitch
# Keep this URL-safe because it is interpolated into DATABASE_URL by Compose.
POSTGRES_PASSWORD=replace-with-a-long-random-value
POSTGRES_DB=twitch_drops

# Local daily backups are pruned after 14 days; copy them off-host as well.
BACKUP_ROOT=/srv/backups/twitch-drop-automator
